<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4F46E5"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hello, Employee"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <Button
            android:id="@+id/tabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:backgroundTint="#4F46E5"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/tabAttendance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Attendance"
            android:backgroundTint="#E2E8F0"
            android:textColor="#4F46E5"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/tabPayslip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Payslip"
            android:backgroundTint="#E2E8F0"
            android:textColor="#4F46E5"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- HOME TAB -->
    <ScrollView
        android:id="@+id/pageHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Location warning -->
            <TextView
                android:id="@+id/tvLocationWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FEF3C7"
                android:padding="12dp"
                android:text="📍 Please go to the work location to punch in"
                android:textColor="#92400E"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- No campaign message -->
            <TextView
                android:id="@+id/tvNoCampaign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F1F5F9"
                android:padding="16dp"
                android:text="No campaign assigned. Contact your admin."
                android:textColor="#64748B"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Campaign card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCampaign"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT CAMPAIGN"
                        android:textSize="11sp"
                        android:textColor="#94A3B8"
                        android:textAllCaps="true"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCampaignName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="20dp"/>

                    <Button
                        android:id="@+id/btnPunch"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="PUNCH IN"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#22C55E"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- ATTENDANCE TAB -->
    <LinearLayout
        android:id="@+id/pageAttendance"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attendance History"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:textColor="#1E293B"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAttendance"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- PAYSLIP TAB -->
    <ScrollView
        android:id="@+id/pagePayslip"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Request Payslip"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etPayslipMonth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Month (YYYY-MM, e.g. 2024-01)"
                android:inputType="text"
                android:background="#FFFFFF"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:padding="14dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnRequestPayslip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send Request to Admin"
                android:backgroundTint="#4F46E5"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Requests"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPayslipRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
